# Bytez3 Nexus — Environment Configuration
# Copy this file to .env and fill in your values

# ======================
# Ollama Provider (Required)
# ======================
CLAUDE_CODE_USE_OLLAMA=1

# Model to use (any Ollama-compatible model)
# Local examples: qwen2.5-coder:7b, llama3.2, deepseek-r1:8b
# Cloud examples: qwen3-coder:480b, llama3.3:70b
ANTHROPIC_MODEL=qwen2.5-coder:7b

# ======================
# Ollama Cloud (Optional)
# ======================
# Set your Ollama Cloud API key to use remote models
# Get yours at: https://ollama.com/settings/keys
# OLLAMA_API_KEY=your-api-key-here

# Custom Ollama endpoint (defaults to localhost:11434 for local, ollama.com for cloud)
# OLLAMA_BASE_URL=http://localhost:11434
